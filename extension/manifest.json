{
  "manifest_version": 3,
  "name": "flip-mimo-api Session Importer",
  "version": "1.0.0",
  "description": "Captura a sessão autenticada da Xiaomi AI Studio e envia ao flip-mimo-api.",
  "permissions": [
    "cookies",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://aistudio.xiaomimimo.com/*",
    "https://*.xiaomimimo.com/*",
    "https://account.xiaomi.com/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "flip-mimo-api Session Importer",
    "default_popup": "popup.html"
  }
}
